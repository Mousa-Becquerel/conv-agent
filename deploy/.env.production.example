# Production .env for the shared solar-intelligence-dev EC2 deploy.
# Copy to /home/ec2-user/conv_agent/.env on the EC2 and fill in real values.
# NEVER commit the filled-in .env.

# ── OpenAI (embeddings + LLM + speech-to-text) ──
OPENAI_API_KEY=

# ── Model overrides (blank keeps defaults) ──
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-large
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TRANSCRIBE_LANGUAGE=it
COLLECTION_NAME=conv_agent_chunks

# ── Postgres (own cluster, isolated on conv-agent-net) ──
POSTGRES_PASSWORD=

# ── Auth (JWT HS256) ──
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# ── CORS ──
# Same-origin (SPA + API both served from dev.solarintelligence.ai), so
# CORS matters only for external tools calling the API directly. Leave
# tight in production.
ALLOWED_ORIGINS=https://dev.solarintelligence.ai

# ── Rate limits ──
CHAT_RATE_LIMIT=30/hour
LOGIN_RATE_LIMIT=10/minute
TRANSCRIBE_RATE_LIMIT=10/hour

# ── Logging + Observability ──
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── Sentry (optional) ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
